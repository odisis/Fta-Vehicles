<?xml version="1.0" encoding="UTF-8"?>
<CVehicleMetadataMgr>

  <ClipSetMaps>
<!------------------------------------------------------------------------------- Animacao Assento Traseiro Direito ------------------------------------------------------------------------------------------------------------------------------------------------->
    <Item type="CClipSetMap">
      <Name>INSIDE_CLIPSET_MAP_HELI_HUEY_REAR_RIGHT</Name>
      <Maps>
        <Item>
          <ClipSetId>anim@veh@helicopter@hueynathan@rear@ps@enter_exit</ClipSetId>
          <VarClipSetId>InsideVarClipSet</VarClipSetId>
          <ConditionFlags />
          <InformationFlags />
        </Item>
      </Maps>
    </Item>
<!------------------------------------------------------------------------------- Animacao Assento Frontal Direito ------------------------------------------------------------------------------------------------------------------------------------------------->
    <Item type="CClipSetMap">
      <Name>INSIDE_CLIPSET_MAP_HELI_HUEY_FRONT_RIGHT</Name>
      <Maps>
        <Item>
          <ClipSetId>anim@veh@helicopter@hueynathan@front@ps@enter_exit</ClipSetId>
          <VarClipSetId>InsideVarClipSet</VarClipSetId>
          <ConditionFlags />
          <InformationFlags />
        </Item>
      </Maps>
    </Item>
<!------------------------------------------------------------------------------- Animacao Assento Frontal Esquerdo ------------------------------------------------------------------------------------------------------------------------------------------------->
    <Item type="CClipSetMap">
      <Name>INSIDE_CLIPSET_MAP_HELI_HUEY_FRONT_LEFT</Name>
      <Maps>
        <Item>
          <ClipSetId>anim@veh@helicopter@hueynathan@front@ds@enter_exit</ClipSetId>
          <VarClipSetId>InsideVarClipSet</VarClipSetId>
          <ConditionFlags />
          <InformationFlags />
        </Item>
      </Maps>
    </Item>
<!------------------------------------------------------------------------------- Animacao Assento Traseiro Esquerdo ------------------------------------------------------------------------------------------------------------------------------------------------->
    <Item type="CClipSetMap">
      <Name>INSIDE_CLIPSET_MAP_HELI_HUEY_REAR_LEFT</Name>
      <Maps>
        <Item>
          <ClipSetId>anim@veh@helicopter@hueynathan@rear@ds@enter_exit</ClipSetId>
          <VarClipSetId>InsideVarClipSet</VarClipSetId>
          <ConditionFlags />
          <InformationFlags />
        </Item>
      </Maps>
    </Item>
   </ClipSetMaps>

 
