<!---------------------------------------------------------------------------------------  Huey - NATHAN  --------------------------------------------------------------------------------------------------------------------------------------------------------->
<!------------------------------------------------------------------------------- Configuração Geral dos Assentos ------------------------------------------------------------------------------------------------------------------------------------------------->


  <VehicleLayoutInfos>
  
	<Item type="CVehicleLayoutInfo">
		<Name>LAYOUT_HUEYNATHAN</Name>
		<Seats>
		  <!-- PILOTO -->
		  <Item>
		  	<SeatInfo ref="SEAT_STANDARD_FRONT_LEFT" />
		  	<SeatAnimInfo ref="SEAT_ANIM_HELI_FRONT_LEFT" />
		  </Item>
		  <!-- COPILOTO -->
		  <Item>
		  	<SeatInfo ref="SEAT_STANDARD_FRONT_RIGHT" />
		  	<SeatAnimInfo ref="SEAT_ANIM_HELI_FRONT_RIGHT" />
		  </Item>
		  <!-- seat_pside_r1 -->
		  <!-- ATIRADOR FRONTAL DIREITO -->
		  <Item>
		  	<SeatInfo ref="SEAT_EXTRA_NO_SHUFFLE_RIGHT_1" />
		  	<SeatAnimInfo ref="SEAT_ANIM_HUEY_SIDE_RIGHT2" />
		  </Item>
		  <!-- seat_pside_r -->
		  <!-- ATIRADOR TRASEIRO DIREITO -->
		  <Item>
		  	<SeatInfo ref="SEAT_STANDARD_REAR_RIGHT" />
		  	<SeatAnimInfo ref="SEAT_ANIM_HUEY_SIDE_RIGHT" />
		  </Item>
		  <!-- seat_dside_r1 -->
		  <!-- ATIRADOR FRONTAL ESQUERDOR -->
		  <Item>
		  	<SeatInfo ref="SEAT_EXTRA_NO_SHUFFLE_LEFT_1" />
		  	<SeatAnimInfo ref="SEAT_ANIM_HUEY_SIDE_LEFT2" />
		  </Item>
		  <!-- seat_dside_r -->
		  <!-- ATIRADOR TRASEIRO ESQUERDOR -->
		  <Item>
		  	<SeatInfo ref="SEAT_STANDARD_REAR_LEFT" />
		  	<SeatAnimInfo ref="SEAT_ANIM_HUEY_SIDE_LEFT" />
		  </Item>
		  <!-- seat_dside_r2 -->
		  <!-- PASSAGEIRO ESQUERDO -->
		  <Item>
		  	<SeatInfo ref="SEAT_EXTRA_NO_SHUFFLE_LEFT_2" />
		  	<SeatAnimInfo ref="SEAT_ANIM_HUEY_SIDE_LEFT3" />
		  </Item>
		  <!-- seat_pside_r2 -->
		  <!-- PASSAGEIRO DIREITO -->
		  <Item>
		  	<SeatInfo ref="SEAT_EXTRA_NO_SHUFFLE_RIGHT_2" />
		  	<SeatAnimInfo ref="SEAT_ANIM_HUEY_SIDE_RIGHT3" />
		  </Item>
		</Seats>
		<EntryPoints>
		  <!-- PILOTO -->
		  <Item>
		  	<EntryPointInfo ref="ENTRY_POINT_STANDARD_FRONT_LEFT" />
		  	<EntryPointAnimInfo ref="ENTRY_POINT_ANIM_HELI_ANNIHILATOR_FRONT_LEFT" />
		  </Item>
		  <!-- COPILOTO -->
		  <Item>
		  	<EntryPointInfo ref="ENTRY_POINT_STANDARD_FRONT_RIGHT" />
		  	<EntryPointAnimInfo ref="ENTRY_POINT_ANIM_HELI_ANNIHILATOR_FRONT_RIGHT" />
		  </Item>
		  <!-- ATIRADOR FRONTAL DIREITO -->
		  <Item>
		  	<EntryPointInfo ref="ENTRY_POINT_HUEY_RIGHT2" />
		  	<EntryPointAnimInfo ref="ENTRY_POINT_ANIM_HELI_HUEY_REAR_RIGHT2" />
		  </Item>
		  <!-- ATIRADOR TRASEIRO DIREITO -->
		  <Item>
		  	<EntryPointInfo ref="ENTRY_POINT_HUEY_RIGHT" />
		  	<EntryPointAnimInfo ref="ENTRY_POINT_ANIM_HELI_HUEY_REAR_RIGHT" />
		  </Item>
		  <!-- ATIRADOR FRONTAL ESQUERDOR -->
		  <Item>
		  	<EntryPointInfo ref="ENTRY_POINT_HUEY_LEFT2" />
		  	<EntryPointAnimInfo ref="ENTRY_POINT_ANIM_HELI_HUEY_REAR_LEFT2" />
		  </Item>
		  <!-- ATIRADOR TRASEIRO ESQUERDOR -->
		  <Item>
		  	<EntryPointInfo ref="ENTRY_POINT_HUEY_LEFT" />
		  	<EntryPointAnimInfo ref="ENTRY_POINT_ANIM_HELI_HUEY_REAR_LEFT" />
		  </Item>
		  <!-- PASSAGEIRO ESQUERDOR -->
		  <Item>
		  	<EntryPointInfo ref="ENTRY_POINT_HUEY_LEFT3" />
		  	<EntryPointAnimInfo ref="ENTRY_POINT_ANIM_HELI_HUEY_REAR_LEFT3" />
		  </Item>
		  <!-- PASSAGEIRO DIREITO -->
		  <Item>
		  	<EntryPointInfo ref="ENTRY_POINT_HUEY_RIGHT3" />
		  	<EntryPointAnimInfo ref="ENTRY_POINT_ANIM_HELI_HUEY_REAR_RIGHT3" />
		  </Item>
		</EntryPoints>
        <LayoutFlags>StreamAnims UseFinerAlignTolerance Use2DBodyBlend</LayoutFlags>
        <BicycleInfo ref="NULL" />
        <HandsUpClipSetId>busted_vehicle_std</HandsUpClipSetId>
        <SteeringWheelOffset x="0.000000" y="0.350000" z="0.320000" />
	</Item>
	
  </VehicleLayoutInfos>	
  
  
